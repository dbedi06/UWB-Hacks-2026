# ──────────────────────────────────────────────────────────────────────
# VoiceMap backend — example env file
# Copy this to `.env` and fill in real values. `.env` is gitignored.
# ──────────────────────────────────────────────────────────────────────

# ─── OpenAI (required) ────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model overrides (defaults shown)
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EXTRACTION_MODEL=gpt-4o-2024-08-06

# ─── Local DB stub ────────────────────────────────────────────────────
# Path to the JSON file that stands in for the Supabase `reports` table.
# Relative paths resolve from the backend/ working directory.
REPORTS_JSON_PATH=data/reports.json

# ─── Feature flags ────────────────────────────────────────────────────
# When true, /api/submit-report returns a canned sample without calling
# OpenAI. Useful for demos. Per-request override: `x-mock: true` header.
MOCK_MODE=false

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins allowed by the FastAPI CORS middleware.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── TODO: enable when the real DB is ready ───────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=

# ─── TODO: enable when geocoding stretch goal is scoped ───────────────
# MAPBOX_TOKEN=
# ENABLE_GEOCODING=false
